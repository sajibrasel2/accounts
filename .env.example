# Server Configuration
PORT=3000

# ═══════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════
# 
# ⚙️ SWITCH BETWEEN LOCAL & PRODUCTION:
# 
# For PRODUCTION (cPanel/Live Server):
# ✅ Uncomment PRODUCTION lines below
# ❌ Comment out LOCALHOST lines
# 
# For LOCALHOST (XAMPP):
# ✅ Uncomment LOCALHOST lines below
# ❌ Comment out PRODUCTION lines
# 
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 🌐 PRODUCTION DATABASE (cPanel/Live Server)
# ---------------------------------------------------------------
# DB_HOST=localhost
# DB_USER=your_cpanel_db_username
# DB_PASSWORD=your_cpanel_db_password
# DB_NAME=your_cpanel_db_name
# ---------------------------------------------------------------

# 💻 LOCALHOST DATABASE (XAMPP)
# ---------------------------------------------------------------
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=local_billing_db
# ---------------------------------------------------------------

# Application Settings
NODE_ENV=development

# ═══════════════════════════════════════════════════════════
# LICENSE CONFIGURATION (Client এখানে license update করবে)
# ═══════════════════════════════════════════════════════════
# 
# 📌 License পেয়েছেন? নিচের 3টি line পরিবর্তন করুন:
# 
# WhatsApp বা Facebook থেকে license message পাবেন।
# সেখান থেকে এই 3টি জিনিস copy করে নিচে paste করুন:
# 
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 
# 🔧 Installation Steps:
# 
# 1. এই ফাইলটি Notepad দিয়ে খুলুন
# 2. নিচের 3টি line খুঁজুন (LICENSE_CLIENT_NAME, LICENSE_KEY, LICENSE_EXPIRY)
# 3. Message থেকে copy করে paste করুন
# 4. Save করুন (Ctrl+S)
# 5. Server restart করুন (Ctrl+C তারপর node server.js)
# 
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 
# ⚠️ গুরুত্বপূর্ণ সতর্কতা:
# 
# ❌ ভুল করবেন না:
# • LICENSE_KEY = SAJIB-... (= এর আগে-পরে space দিবেন না!)
# • License key এর spelling ভুল করবেন না
# • তারিখ DD-MM-YYYY format এ দিবেন না (ভুল!)
# 
# ✅ সঠিক উপায়:
# • LICENSE_KEY=SAJIB-... (কোন space নেই)
# • হুবহু copy-paste করুন
# • তারিখ YYYY-MM-DD format এ হতে হবে (যেমন: 2025-01-31)
# 
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 
# 📝 Example (নমুনা):
# 
# LICENSE_CLIENT_NAME=রাসেল সাহেব
# LICENSE_KEY=SAJIB-ABC12345-XYZ67890
# LICENSE_EXPIRY=2025-01-31
# 
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 
# 🆘 সমস্যা হলে:
# 
# যদি "LICENSE INVALID" error দেখায়, তাহলে:
# 1. উপরের 3টি line আবার check করুন
# 2. কোন extra space আছে কিনা দেখুন
# 3. File save করেছেন কিনা চেক করুন
# 4. Server restart করেছেন কিনা দেখুন
# 
# তবুও সমস্যা হলে যোগাযোগ করুন:
# 📱 WhatsApp: 01739354392
# 💬 Facebook: fb.com/sajibrasel2
# 📧 Email: raselsajib25@gmail.com
# 
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 
# License না দিলে Demo mode এ চলবে (সীমিত সময়ের জন্য)
# 
# ═══════════════════════════════════════════════════════════

# নিচের 3টি line পরিবর্তন করুন (Message থেকে copy-paste করুন):

LICENSE_CLIENT_NAME=Demo User
LICENSE_KEY=DEMO-KEY-EXPIRES-SOON
LICENSE_EXPIRY=2025-01-31

